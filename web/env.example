# ---- Supabase (banco de dados) ----
# Crie um projeto grátis em https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Google Gemini (gratuito, gera os insights) ----
# Crie a chave em https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ---- Meta / Instagram Graph API (para analisar O SEU PRÓPRIO perfil) ----
# Criar app em https://developers.facebook.com -> tipo "Business"
# Produto: "Instagram Graph API" (via conta Instagram Business/Creator vinculada a uma Página do Facebook)
META_APP_ID=
META_APP_SECRET=
# URL pública do seu deploy na Vercel + /api/auth/instagram/callback
META_REDIRECT_URI=https://SEU-PROJETO.vercel.app/api/auth/instagram/callback

# ---- Segurança extensão <-> backend ----
# Token que a extensão vai enviar no header Authorization. Gere qualquer string aleatória longa.
EXTENSION_API_TOKEN=troque-por-um-token-aleatorio-longo
